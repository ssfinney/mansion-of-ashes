  "format-version": "2.37.3",
  "start": "Title",
  "zoom": 1
}

:: StoryStyles [stylesheet]
/* =========================================
   Base Variables / Theme
========================================= */
:root {
  --bg: #11100f;
  --surface: rgba(30, 24, 20, 0.84);
  --surface-soft: rgba(24, 19, 16, 0.68);
  --border: #3d3530;
  --border-soft: #2f2823;
  --text: #d8d1c3;
  --text-soft: #b8af9f;
  --text-dim: #9f9383;
  --text-muted: #8f8375;
  --text-faint: #7f7468;
  --accent: #c8a96e;
  --accent-hover: #e8c98e;
  --shadow: rgba(0, 0, 0, 0.32);
}

/* =========================================
   Typography
========================================= */
body {
  background: var(--bg);
  color: var(--text);
  font-family: Georgia, "Times New Roman", serif;
  line-height: 1.7;
  font-size: 17px;
}

body.text-size-large {
  font-size: 19px;
}

body.line-height-relaxed {
  line-height: 1.9;
}

.passage {
  font-size: 1.03rem;
}

body.text-size-large .passage {
  font-size: 1.08rem;
}

body.line-height-relaxed .passage {
  line-height: 1.85;
}

.reveal-text {
  color: #cfc4b0;
  font-style: italic;
  display: block;
  margin: 0.65rem 0;
}

/* =========================================
   Page Layout
========================================= */
#story {
  max-width: 52rem;
}

#passages {
  padding: 2rem 1.5rem;
}

hr.scene-break {
  border: none;
  border-top: 1px solid #4a453f;
  margin: 1.5rem 0;
}

/* =========================================
   Title Page
========================================= */
.title-shell {
  text-align: center;
  padding: 0.7rem 0 0.9rem;
}

.title-kicker {
  margin: 0;
  font-size: 0.75rem;
  letter-spacing: 0.24em;
  color: var(--text-faint);
  text-transform: uppercase;
}

.title-name {
  margin: 0.65rem 0 0;
  font-size: clamp(2rem, 4.4vw, 2.7rem);
  letter-spacing: 0.03em;
  color: var(--text);
}

.title-meta {
  margin: 0.75rem 0 0;
  color: var(--text-muted);
  font-size: 0.9rem;
}

.title-intro {
  max-width: 42rem;
  margin: 0 auto;
}

.title-actions {
  display: grid;
  justify-content: center;
  justify-items: center;
  row-gap: 0.55rem;
  margin: 1.1rem 0 0.2rem;
}

/* =========================================
   HUD
========================================= */
.hud {
  margin: 0 0 1.5rem;
  padding: 0.9rem 1rem;
  border: 1px solid var(--border);
  background: var(--surface);
  box-shadow: 0 8px 24px -18px var(--shadow);
  color: var(--text-soft);
  font-size: 0.88rem;
  line-height: 1.5;
}

.hud-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.7rem 1rem;
}

.hud-block {
  min-width: 0;
}

.hud-label {
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 0.76rem;
  display: block;
  margin-bottom: 0.18rem;
}

.hud-value {
  color: #d4c8b4;
  overflow-wrap: break-word;
}

.hud-dim {
  color: var(--text-dim);
  font-style: italic;
}

.hud-controls {
  margin-top: 0.8rem;
  border-top: 1px solid var(--border-soft);
  padding-top: 0.55rem;
  text-align: right;
  font-size: 0.78rem;
}

/* =========================================
   Links And Buttons
========================================= */
a.link-internal,
a.link-external {
  color: var(--accent);
  text-decoration: none;
  transition: color 120ms ease, border-color 120ms ease, background-color 120ms ease;
}

a.link-internal:hover,
a.link-external:hover,
a.link-internal:focus-visible,
a.link-external:focus-visible {
  color: var(--accent-hover);
}

.title-actions a.link-internal,
.ending-actions a.link-internal,
.hud-controls a.link-internal {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.4rem 0.8rem;
  border: 1px solid var(--border);
  background: var(--surface-soft);
  color: #d7c8b0;
  min-height: 42px;
  border-radius: 2px;
}

.title-actions a.link-internal:hover,
.ending-actions a.link-internal:hover,
.hud-controls a.link-internal:hover,
.title-actions a.link-internal:focus-visible,
.ending-actions a.link-internal:focus-visible,
.hud-controls a.link-internal:focus-visible {
  border-color: #5b4f44;
  background: rgba(40, 32, 27, 0.82);
  text-decoration: none;
}

.title-actions > a.link-internal:first-of-type,
.ending-actions > a.link-internal:first-of-type {
  min-width: min(16rem, 100%);
  border-color: #665540;
  background: rgba(53, 42, 33, 0.84);
  font-weight: 600;
  letter-spacing: 0.02em;
}

.inline-sep {
  color: var(--text-faint);
  margin: 0 0.35rem;
}

/* =========================================
   Endings / Restart Controls
========================================= */
.ending-title {
  font-size: 0.9rem;
  color: var(--text-faint);
  text-transform: uppercase;
  letter-spacing: 0.22em;
  margin-bottom: 1.4rem;
  border-top: 1px solid var(--border);
  padding-top: 1.2rem;
}

.ending-actions {
  margin-top: 1rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
}

/* =========================================
   Audio / Preferences Controls
========================================= */
.system-panel {
  border: 1px solid var(--border);
  background: var(--surface-soft);
  padding: 0.85rem 0.95rem;
  margin-top: 0.9rem;
}

.system-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem 0.75rem;
  padding: 0.45rem 0;
  border-bottom: 1px solid rgba(80, 69, 61, 0.45);
}

.system-row:last-child {
  border-bottom: 0;
}

.system-label {
  font-size: 0.82rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.system-value {
  color: var(--text);
  font-size: 0.95rem;
}

.system-active {
  color: var(--accent-hover);
  font-weight: 600;
}

/* =========================================
   Reduced Ornament Mode
========================================= */
body.reduced-ornament .hud,
body.reduced-ornament .system-panel,
body.reduced-ornament .title-actions a.link-internal,
body.reduced-ornament .ending-actions a.link-internal,
body.reduced-ornament .hud-controls a.link-internal {
  box-shadow: none;
  background: rgba(22, 18, 15, 0.92);
  border-color: #362f2a;
}

body.reduced-ornament hr.scene-break {
  border-color: #362f2a;
}

/* =========================================
   Power-Off Visual State
========================================= */
body.power-off .hud {
  border-color: #2a2420;
  background: rgba(16, 12, 10, 0.92);
}

body.power-off hr.scene-break {
  border-top-color: #2a2420;
}

/* =========================================
   Responsive / Mobile Overrides
========================================= */
@media (max-width: 768px) {
  #story {
    max-width: 44rem;
  }

  #passages {
    padding: 1.5rem 1rem;
    padding-bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
    padding-left: calc(1rem + env(safe-area-inset-left, 0px));
    padding-right: calc(1rem + env(safe-area-inset-right, 0px));
  }

  .passage {
    font-size: 1rem;
    line-height: 1.68;
  }

  .hud {
    font-size: 0.84rem;
    padding: 0.75rem 0.8rem;
  }

  .hud-grid {
    grid-template-columns: 1fr;
    gap: 0.55rem;
  }

  .hud-controls {
    text-align: left;
  }

  a.link-internal,
  a.link-external,
  .hud-controls a.link-internal,
  .title-actions a.link-internal,
  .ending-actions a.link-internal {
    min-height: 44px;
  }

  .title-actions {
    width: 100%;
  }

  .title-actions > a.link-internal:first-of-type {
    width: min(100%, 22rem);
  }

  .system-row {
    flex-direction: column;
    align-items: flex-start;
  }

  /* Sidebar: full-width overlay on mobile */
  #ui-bar {
    width: 100% !important;
    max-width: 100% !important;
    left: 0 !important;
    box-shadow: none !important;
  }

  #ui-bar.stowed {
    left: calc(-100% + 2.75rem) !important;
  }

  #ui-bar-toggle {
    min-width: 44px !important;
    min-height: 44px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
}

@media (max-width: 390px) {
  #passages {
    padding: 1.2rem 0.85rem;
    padding-bottom: calc(1.2rem + env(safe-area-inset-bottom, 0px));
    padding-left: calc(0.85rem + env(safe-area-inset-left, 0px));
    padding-right: calc(0.85rem + env(safe-area-inset-right, 0px));
  }

  .passage {
    font-size: 0.97rem;
    line-height: 1.65;
  }

  .hud {
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .title-name {
    font-size: 1.8rem;
  }
}

:: StoryCaption
<div class="hud">
  <div class="hud-grid">
    <div class="hud-block">
      <span class="hud-label">Inventory</span>
      <span class="hud-value">
        <<set _inv = []>>
        <<if $hasMatches>><<run _inv.push("matches")>><</if>>
        <<if $hasSilverKey>><<run _inv.push("silver key")>><</if>>
        <<if $hasDiaryPage>><<run _inv.push("diary page")>><</if>>
        <<if $hasSpareFuse>><<run _inv.push("spare fuse")>><</if>>
        <<if _inv.length > 0>>
          <<= _inv.join(", ")>>
        <<else>>
          <span class="hud-dim">nothing yet</span>
        <</if>>
      </span>
    </div>

    <div class="hud-block">
      <span class="hud-label">House</span>
      <span class="hud-value">
        <<if $powerOn>>power restored<<else>><span class="hud-dim">dark</span><</if>>
      </span>
    </div>

    <div class="hud-block">
      <span class="hud-label">Clues</span>
      <span class="hud-value">
        <<set _c = 0>>
        <<if $readLedger>><<set _c += 1>><</if>>
        <<if $hasDiaryPage>><<set _c += 1>><</if>>
        <<if $hasSilverKey>><<set _c += 1>><</if>>
        <<if $heardLockedDoor>><<set _c += 1>><</if>>
        <<if $sawConservatoryReveal>><<set _c += 1>><</if>>
        <<= _c>> / 5
      </span>
    </div>
  </div>

  <div class="hud-controls">
    [[Preferences->Preferences]]
  </div>
</div>

